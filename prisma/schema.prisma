generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = "file:./dev.db"
}

model PackingItem {
    item_id            String   @id @default(cuid())
    listId             String
    name               String
    category           String
    dayMultiplier      Int?
    dayThreshold       Int?
    relevantForWeather String?
    onlyIfWeekday      Boolean?
    onlyIfAbroad       Boolean?
    // positive / negative number of days relative to trip begin date
    dueShift           Int?
    afterReturn        Boolean?
    additionalLabels   String?
    addTripNameToTask  Boolean?

    // Relations
    packingList PackingList? @relation(fields: [listId], references: [id])
}

model PackingList {
    id           String        @id @default(cuid())
    name         String
    type         String
    packingItems PackingItem[]
}
